---
source: core/src/ast/structs.rs
expression: "Struct::new(&syn::parse_quote!\n{\n    #[doc = r\" Some docs.\"] #[diplomat::rust_link(foo::Bar, Struct)] struct\n    MyLocalStruct { a: i32, b: Box<MyLocalStruct> }\n}, true, &Default::default(), &SpanLocation::None)"
---
name:
  - MyLocalStruct
  - start_line: 1
    column_line: 0
    range:
      start: 0
      end: 0
    span_location: None
docs:
  - - cfg: Star
      lines: Some docs.
  - - path:
        elements:
          - - foo
            - start_line: 1
              column_line: 0
              range:
                start: 0
                end: 0
              span_location:
                LocalSource: ", Struct"
          - - Bar
            - start_line: 1
              column_line: 0
              range:
                start: 0
                end: 0
              span_location:
                LocalSource: ", Struct"
      typ: Struct
      display: Normal
lifetimes: {}
fields:
  - - - a
      - start_line: 1
        column_line: 0
        range:
          start: 0
          end: 0
        span_location: None
    - Primitive: i32
    - - - cfg: Star
          lines: ""
      - []
    - {}
  - - - b
      - start_line: 1
        column_line: 0
        range:
          start: 0
          end: 0
        span_location: None
    - Box:
        Named:
          path:
            elements:
              - - MyLocalStruct
                - start_line: 1
                  column_line: 0
                  range:
                    start: 0
                    end: 0
                  span_location: None
          lifetimes: []
    - - - cfg: Star
          lines: ""
      - []
    - {}
methods: []
output_only: true
attrs: {}
