                line: 1
                col: 0
              range:
                start: 0
                end: 0
              span_location: None
          docs:
            - - cfg: Star
                lines: ""
            - []
          lifetimes: {}
          fields: []
          methods: []
          output_only: false
          attrs: {}
    declared_traits: {}
    declared_functions: {}
    sub_modules: []
    attrs: {}
  other:
