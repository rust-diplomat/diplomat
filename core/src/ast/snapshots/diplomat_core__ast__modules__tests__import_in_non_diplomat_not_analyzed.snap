---
source: core/src/ast/modules.rs
expression: "File::from(&syn::parse_quote!\n{\n    #[diplomat::bridge] mod ffi { struct Foo {} } mod other\n    { use something::*; }\n})"
---
modules:
  ffi:
    name:
      - ffi
