                    column_line: 0
                    range:
                      start: 0
                      end: 0
                    span_location: None
            lifetimes: []
    attrs: {}
output_type:
  Option:
    - Reference:
        - Named:
            - a
            - start_line: 1
              column_line: 0
              range:
                start: 0
                end: 0
              span_location: None
        - Immutable
        - Named:
            path:
              elements:
                - - SomeType
                  - start_line: 1
                    column_line: 0
                    range:
                      start: 0
                      end: 0
