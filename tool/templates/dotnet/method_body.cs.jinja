{#- Shared idiomatic method body — encoding setup, pin chain, raw call,
    return wrap. The caller is responsible for the method declaration line,
    the `unsafe { }` wrap, and (for opaque) the disposed check.

    Body indent comes from `method.body_indent()`:
      - 12 spaces normally (inside `unsafe { }` inside a class method)
      - +4 when the method has pinned inputs (`try { ... }` wrapping —
        an exception between `Pin` and the returned wrapper taking
        ownership must dispose the pins, or they leak permanently)
      - +4 when the method has `fixed (...) { ... }` wrapping,
        so the body reads as nested under the wrapping line rather than
        flush with it.

    Validation / to-bytes / pin-declaration statements stay at the
    method-body level (12 spaces) because they sit OUTSIDE the try/fixed
    blocks; `fixed (...)` lines use `method.fix_indent()` (12, or 16 when
    nested in the pin try); only the code inside the blocks uses `bi`.

    Control tags below are indented to mirror C# nesting for readability.
    Every tag uses the `{%-` left-trim, which removes the tag's own leading
    whitespace AND the preceding line's newline, so the indentation is
    purely cosmetic and does not reach the generated output.

    Variables in scope (from the caller's `for method in methods` loop):
      - method: MethodInfo
      - name:   the owner type's bare C# name (e.g. "Color", "Point2D")
-#}
{%- let bi = method.body_indent() -%}
{#- Validation (null / disposed checks) MUST precede the to-bytes encoding
    step: a string param's `Encoding.UTF8.GetBytes(arg)` would otherwise
    throw before our `ArgumentNullException(nameof(arg))` runs, surfacing
    the wrong parameter name. No validation statement depends on a
    to-bytes output, so this ordering is always safe. #}
{%- for statement in method.inputs.validation_statements %}
            {{ statement }}
{%- endfor %}
{%- for statement in method.inputs.to_bytes_statements %}
            {{ statement }}
{%- endfor %}
{%- if method.has_pinned_inputs() %}
{%- for statement in method.pin_declaration_statements() %}
            {{ statement }}
{%- endfor %}
            try
            {
{%- for statement in method.pin_assignment_statements() %}
                {{ statement }}
{%- endfor %}
{%- endif %}
{%- if !method.inputs.fix_statements.is_empty() %}
    {%- for statement in method.inputs.fix_statements %}
{{ method.fix_indent() }}{{ statement }}
    {%- endfor %}
{{ method.fix_indent() }}{
{%- endif %}
{%- if method.return_type.is_write() %}
    {#- Write methods return `string`. Allocate the writer in this frame,
        pass its address to Rust, read the buffer back, dispose. The
        low-level DiplomatWrite never appears on the public API.
        try/finally guarantees the unmanaged buffer is freed even if the
        raw call or ToUnicode() throws (the error-arm throw sits inside
        the try; finally still runs). #}
{{ bi }}DiplomatWrite writeable = new DiplomatWrite();
{{ bi }}try
{{ bi }}{
    {%- if method.error_info.is_some() %}
{{ bi }}    var result = Raw.{{ name }}.{{ method.name }}({{ method.raw_call_args_with_writer() }});
    {%- for keep_alive in method.keep_alive_statements() %}
{{ bi }}    {{ keep_alive }}
    {%- endfor %}
{{ bi }}    if (!result.IsOk)
{{ bi }}    {
{{ bi }}        {{ method.error_throw_statement() }}
{{ bi }}    }
    {%- else %}
{{ bi }}    Raw.{{ name }}.{{ method.name }}({{ method.raw_call_args_with_writer() }});
    {%- for keep_alive in method.keep_alive_statements() %}
{{ bi }}    {{ keep_alive }}
    {%- endfor %}
    {%- endif %}
{{ bi }}    return writeable.ToUnicode();
{{ bi }}}
{{ bi }}finally
{{ bi }}{
{{ bi }}    writeable.Dispose();
{{ bi }}}
{%- else if method.error_info.is_some() %}
{{ bi }}var result = {{ method.raw_call_expr(name) }};
{%- for keep_alive in method.keep_alive_statements() %}
{{ bi }}{{ keep_alive }}
{%- endfor %}
{{ bi }}if (!result.IsOk)
{{ bi }}{
{{ bi }}    {{ method.error_throw_statement() }}
{{ bi }}}
{{ bi }}{{ method.success_return_statement("result.Ok") }}
{%- else if method.return_type.is_void() %}
{{ bi }}{{ method.raw_call_statement(name) }}
{%- for keep_alive in method.keep_alive_statements() %}
{{ bi }}{{ keep_alive }}
{%- endfor %}
{%- else if method.can_return_raw_call_directly() && !method.has_keep_alive() %}
{{ bi }}{{ method.direct_raw_return_statement(name) }}
{%- else %}
{{ bi }}{{ method.success_result_declaration(name) }}
{%- for keep_alive in method.keep_alive_statements() %}
{{ bi }}{{ keep_alive }}
{%- endfor %}
{{ bi }}{{ method.success_return_statement("result") }}
{%- endif %}
{%- if !method.inputs.fix_statements.is_empty() %}
{{ method.fix_indent() }}}
{%- endif %}
