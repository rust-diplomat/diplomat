{%- if !cpp_to_c_fields.is_empty() %}
inline {{ctype}} {{type_name}}::AsFFI() const {
    return {{ctype}} {
{%- for field in cpp_to_c_fields %}
        /* .{{field.var_name}} = */ {{field.expression}},
{%- endfor %}
    };
}

inline {{type_name}} {{type_name}}::FromFFI({{ctype}} c_struct) {
    return {{type_name}} {
{%- for field in c_to_cpp_fields %}
        /* .{{field.var_name}} = */ {{field.expression}},
{%- endfor %}
    };
}

{%- if tuplable %}
{%- let field_names = fields.iter().map(NamedType::type_name).collect::<Vec<_>>() -%}
{%- let tuple_struct = fmt.fmt_tuple(field_names.clone()) %}
inline {{ctype}} {{type_name}}::AsTupleFFI({{tuple_struct}} tuple) {
    return {{ctype}} {
{%- for field in tuple_to_c_fields %}
        /* .{{field.var_name}} = */ {{field.expression}},
{%- endfor %}
    };
}

inline {{tuple_struct}} {{type_name}}::TupleFromFFI({{ctype}} c_struct) {
    return {{tuple_struct}}{
{%- for field in c_to_cpp_fields %}
        /* .{{field.var_name}} = */ {{field.expression}},
{%- endfor %}
    };
}
{%- endif %}
