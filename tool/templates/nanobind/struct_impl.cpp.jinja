{%- let is_self_opaque = false -%}

{%- if is_sliceable %}
// Python lists are represented as PyObject**, which runs somewhat counter to any use cases where we want to be able to transparently pass over lists without copying over memory in any ways.
// bind_vector solves this issue by exposing std::vector<{{type_name}}> as a type that will exist inside of C++, with functions to access its memory from Python.
// TL;DR: this creates a faux list type that makes it easier to pass vectors of this type in Python without copying. 
nb::bind_vector<std::vector<{{type_name}}>>(mod, "{{type_name_unnamespaced}}Slice"); 
{% endif -%}

{% if !extra_init_code.pre.is_empty() %}
{{extra_init_code.pre}}
{% endif -%}

nb::class_<{{type_name}}> st(mod, "{{type_name_unnamespaced}}"{% if let Some(docs) = docs %}, {{docs}}{% endif %});
st
    {%- if !has_constructor && !is_out %}
    .def(nb::init<>())

    {%- if fields.len() > 0 && !is_out %}
    .def(nb::init<
    {%- for f in fields -%}
    {% if !loop.first %}, {% endif %}{{f.type_name}}
    {%- endfor -%}
    >(), 
    {%- for f in fields -%}
    {%- if !loop.first %}, {% endif %} "{{f.name}}"_a
    {%- if !f.type_name.starts_with("std::unique_ptr") -%}
    .none()
    {%- endif -%}
    {%- endfor -%}
    )
    {%- endif -%}

    {%- endif -%}
    {%- decl prop_type -%}
    {%- if is_out -%} {% let prop_type = "ro" %} {%- else -%} {%- let prop_type = "rw" -%}{%- endif -%}

    {%- for f in fields %}
    {%- if !f.type_name.starts_with("std::unique_ptr") %}
    .def_{{prop_type}}("{{f.name}}", &{{type_name}}::{{f.name}}{% if let Some(doc) = f.docstring %}, {{doc}}{% endif %})
    {%- else %}
    .def_prop_{{prop_type}}("{{f.name}}",
        [](const {{type_name}}& self) { return self.{{f.name}}.get(); }
    {%- if !is_out %},
        []({{type_name}}& self, {{f.type_name}}&& v) { self.{{f.name}} = std::move(v); }
    {%- endif %}
    {%- if let Some(doc) = f.docstring %}, {{doc}}{% endif %}
    )
    {%- endif -%}
    {%- endfor %}

{%- for m in methods -%}
{% include "method_impl.cpp.jinja" %}
{%- endfor %};

{%- if !extra_init_code.inner.is_empty() %}
{{extra_init_code.inner}}
{% endif -%}
