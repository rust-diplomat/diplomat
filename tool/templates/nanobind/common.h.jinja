    // Nanobind does not ship with support for casting char32_t, which seems to be an oversight.
    // Remove this block when upstream support is added
    template <>
    struct type_caster<char32_t>
    {
        using Value = char32_t;
        Value value;
        Py_ssize_t size;
        static constexpr auto Name = const_name("str");
        template <typename T>
        using Cast = char32_t;

        bool from_python(handle src, uint8_t, cleanup_list *) noexcept
        {
            value = PyUnicode_ReadChar(src.ptr(), 0);
            if (!value)
            {
                PyErr_Clear();
                return false;
            }
            size = PyUnicode_GetLength(src.ptr());
            return true;
        }

        static handle from_cpp(const char32_t *value, rv_policy,
                               cleanup_list *) noexcept
        {
            if (value == nullptr)
            {
                PyObject *result = Py_None;
                Py_INCREF(result);
                return result;
            }
            size_t len = 0;
            const char32_t *str = value;
            while (*str != U'\0')
            {
                len++;
                str++;
            }
            return PyUnicode_DecodeUTF32(reinterpret_cast<const char *>(value), len * 4, nullptr, nullptr);
        }

        static handle from_cpp(char32_t value, rv_policy, cleanup_list *) noexcept
        {
            return PyUnicode_DecodeUTF32(reinterpret_cast<const char *>(&value), 4, nullptr, nullptr);
        }

        template <typename T_>
        NB_INLINE bool can_cast() const noexcept
        {
            return (value && size == 1);
        }

        explicit operator char32_t()
        {
            if (can_cast<char32_t>())
                return value;
            else
                throw next_overload();
        }
    };

    template <typename T>
    struct type_caster<std::reference_wrapper<T>>
    {
        using Value = std::reference_wrapper<T>;
        Value value;
        Py_ssize_t size;
        using Caster = make_caster<T>;
        static constexpr auto Name = Caster::Name;

        static handle from_cpp(std::reference_wrapper<T> value, rv_policy p, cleanup_list *cl) noexcept
        {
            return Caster::from_cpp(value.get(), p, cl);
        }

        NB_INLINE bool can_cast() const noexcept { return Caster::template can_cast<T>(); }
    };

    template<typename E>
    void set_py_error(E&& err, rv_policy p, cleanup_list* cl) noexcept {
        using V = std::conditional_t<std::is_reference_v<E>, std::reference_wrapper<std::remove_reference_t<E>>, E>;
        using ErrCaster = make_caster<V>;

        // Convert the error into a Python object. `err` is a forwarding reference (not taken by
        // value) so a borrowed, possibly-const view of a move-only opaque error (e.g.
        // Optional<Ref<Foo,...>>::value() on a result's error variant) doesn't need to be
        // copied/moved into a new local just to pass it along.
        auto errorPyV = ErrCaster::from_cpp(forward_like_<V>(std::forward<E>(err)), p, cl);
        if (errorPyV.is_valid())
        {
            PyErr_SetObject(PyExc_Exception, errorPyV.ptr());
            // PyErr_SetObject takes ownership (https://github.com/python/cpython/blob/fa73fd473f00dd231f59e44798a3d00a46322658/Python/errors.c#L151)
            // but Nanobind expects Python to take ownership directly. So we decref after PyErr_SetObject takes ownership, to remove Nanobind's reference:
            Py_DECREF(errorPyV.ptr());
        }
        else
        {
            char error_msg[512];
            snprintf(error_msg, sizeof(error_msg), "Cannot convert unknown type %s to python exception.", typeid(E).name());
            PyErr_SetString(PyExc_Exception, error_msg);
        }
    }

    template <typename T, typename E>
    struct type_caster<{{lib_name}}::diplomat::result<T, E>>
    {
        using U = std::conditional_t<std::is_reference_v<T>, std::reference_wrapper<std::remove_reference_t<T>>, T>;
        using V = std::conditional_t<std::is_reference_v<E>, std::reference_wrapper<std::remove_reference_t<E>>, E>;
        using Value = {{lib_name}}::diplomat::result<T, E>;
        // Can't store result<T, E> directly since T& will create compiler errors.
        std::optional<U> ok_val;
        std::optional<V> err_val;
        bool is_ok;
        Py_ssize_t size;
        using Caster = make_caster<U>;
        static constexpr auto Name = []() constexpr {
            if constexpr (std::is_same_v<U, std::monostate>) {
                return const_name("None");
            } else {
                return Caster::Name;
            }
        }();

        static handle from_cpp({{lib_name}}::diplomat::result<T, E> value, rv_policy p, cleanup_list *cl) noexcept
        {
            if (value.is_ok()) {
                if constexpr (std::is_same_v<U, std::monostate>) {
                    return none().release();
                } else if constexpr (std::is_reference_v<T>) {
                    return Caster::from_cpp(forward_like_<U>(std::move(value).ok().value()), p, cl);
                } else if constexpr ({{lib_name}}::diplomat::is_pointer_like_v<T> && std::is_copy_constructible_v<T>) {
                    // Ref-shaped `T`: `.ok().value()` hands back the dereferenced `Foo&&` (see the
                    // Ref-based `Optional` specialization in runtime.hpp.jinja), whose address is
                    // part of the temporary `Optional<T>` this whole expression produced --
                    // dangling the instant this function returns. Heap-allocate a small,
                    // permanently "leaked" `Foo` wrapper holding the same pointer instead
                    // (mirroring the `Ref<T,CPtr>`/`Optional<T>` casters above); rv_policy::reference
                    // means nanobind never deletes it.
                    using OkValueType = typename {{lib_name}}::diplomat::Optional<T>::value_type;
                    OkValueType&& ok_ref = std::move(value).ok().value();
                    using CPtr = std::remove_pointer_t<decltype(ok_ref.AsFFI())>;
                    auto* heap_view = new OkValueType(OkValueType::FromFFI(const_cast<std::remove_const_t<CPtr>*>(ok_ref.AsFFI())));
                    return make_caster<OkValueType>::from_cpp(heap_view, rv_policy::reference, cl);
                } else {
                    // `.ok().value()` doesn't always hand back a `T` -- for owned-opaque `T`,
                    // `Optional<T>::value_type` is `T` itself, so this is unchanged from before.
                    using OkValueType = typename {{lib_name}}::diplomat::Optional<T>::value_type;
                    return make_caster<OkValueType>::from_cpp(forward_like_<OkValueType>(std::move(value).ok().value()), p, cl);
                }
            }

            if constexpr ({{lib_name}}::diplomat::is_pointer_like_v<E> && std::is_copy_constructible_v<E>) {
                // Same dangling-temporary concern as the Ref-shaped `T` branch above, for the error
                // variant.
                using ErrValueType = typename {{lib_name}}::diplomat::Optional<E>::value_type;
                ErrValueType&& err_ref = std::move(value).err().value();
                using CPtr = std::remove_pointer_t<decltype(err_ref.AsFFI())>;
                auto* heap_view = new ErrValueType(ErrValueType::FromFFI(const_cast<std::remove_const_t<CPtr>*>(err_ref.AsFFI())));
                // Pass the raw pointer, as an xvalue (not `*heap_view`, and not the bare lvalue
                // `heap_view`) -- set_py_error's forwarding-reference parameter would otherwise
                // deduce a reference type (to the pointee, or to the pointer variable itself),
                // which its own is_reference_v<E> check (a plain std::is_reference_v, unlike
                // nanobind's own reference-stripping is_pointer_v used elsewhere in this file) can't
                // tell apart from the genuine-Rust-&T convention it's designed for. A pointer
                // argument also keeps rv_policy::reference from being downgraded to `move` by
                // infer_policy, which only pointer arguments are exempt from.
                set_py_error(std::move(heap_view), rv_policy::reference, cl);
            } else {
                set_py_error(std::move(value).err().value(), p, cl);
            }

            return nullptr;
        }

        template <typename T_>
        using Cast = Value;
        operator Value() {
            if (is_ok) {
                return {{lib_name}}::diplomat::Ok<T>(forward_like_<U>(ok_val.value()));
            } else {
                return {{lib_name}}::diplomat::Err<E>(forward_like_<V>(err_val.value()));
            }
        }

        bool from_python(handle src, uint8_t flags, cleanup_list* cleanup) noexcept  {
            uint8_t local_flags = flags_for_local_caster<U>(flags);

            // We raise an exception above, but I think it's okay just to check if our conversion succeeds:
            auto caster = make_caster<T>();
            if (caster.from_python(src, local_flags, cleanup)) {
                is_ok = true;
                if constexpr(std::is_reference_v<T>) {
                    ok_val = std::optional(std::reference_wrapper(caster.operator cast_t<T>()));
                } else {
                    ok_val = std::optional(caster.operator cast_t<T>());
                }
                return true;
            } else {
                auto err_caster = make_caster<E>();
                uint8_t err_local_flags = flags_for_local_caster<E>(flags);
                if (err_caster.from_python(src, err_local_flags, cleanup)) {
                    is_ok = false;
                    if constexpr(std::is_reference_v<E>) {
                        err_val = std::optional(std::reference_wrapper(err_caster.operator cast_t<E>()));
                    } else {
                        err_val = std::optional(err_caster.operator cast_t<E>());
                    }
                    return true;
                }
            }

            return false;
        }

        NB_INLINE bool can_cast() const noexcept { return Caster::template can_cast<U>(); }
    };

    // `Ref<Foo, CPtr>` (`FooRef`/`FooRefMut`) used directly -- e.g. a struct field, callback
    // param/return, or tuple element, anywhere `Optional<Ref<...>>`'s value_type trick (see below)
    // doesn't apply since there's no Optional wrapping it -- is a distinct C++ type from `Foo`.
    // Without a caster of its own, nanobind's fallback caster would treat it as its own,
    // never-registered Python type (producing a raw C++ type name like
    // "somelib::diplomat::Ref<somelib::Foo, somelib::capi::Foo const>" in stubs/errors, and
    // failing to actually produce a `Foo` object at runtime). Delegate straight to `Foo`'s own
    // already-registered caster via `AsFFI()`/`FromFFI()` instead.
    template <typename T, typename CPtr>
    struct type_caster<{{lib_name}}::diplomat::Ref<T, CPtr>> {
        using Value = {{lib_name}}::diplomat::Ref<T, CPtr>;
        using Caster = make_caster<T>;

        static constexpr auto Name = Caster::Name;
        template <typename T_>
        using Cast = Value;
        template <typename T_>
        static constexpr bool can_cast() { return true; }

        // `Ref`'s own default constructor is private (a `Ref` should never point at nothing), so
        // default-initialize via `FromFFI(nullptr)` instead -- overwritten by from_python below on
        // success, and otherwise never observed since a failed cast reports failure regardless.
        Value value = Value::FromFFI(nullptr);
        operator Value() { return value; }

        bool from_python(handle src, uint8_t flags, cleanup_list* cleanup) noexcept {
            Caster caster;
            if (!caster.from_python(src, flags, cleanup) || !caster.template can_cast<T>()) {
                return false;
            }
            T& ref = caster;
            value = Value::FromFFI(ref.AsFFI());
            return true;
        }

        static handle from_cpp(Value src, rv_policy policy, cleanup_list* cleanup) {
            return Caster::from_cpp(src.get(), policy, cleanup);
        }
    };

    // `diplomat::Optional<T>` is used everywhere `std::optional<T>` would otherwise appear in
    // generated signatures (see runtime.hpp.jinja for why: it niche-optimizes pointer-like T --
    // owned opaques and Ref<Foo, CPtr> -- to a single pointer instead of paying for a separate
    // presence flag). Its API surface (`value_type`, `operator bool()`, `reset()`, `emplace()`,
    // `operator*()`) intentionally mirrors `std::optional<T>`'s closely enough that nanobind's own
    // `optional_caster` (normally used for `std::optional<T>`, but generic over any type shaped
    // like it) works here unmodified -- so `Optional<Foo>`/`Optional<FooRef>` get exactly the same
    // `Optional[...]` Python typing and `None`/value conversion as `std::optional<Foo>` would,
    // with no separate caster logic to maintain. For the pointer-like specializations,
    // `Optional<T>::value_type` is deliberately the wrapped opaque type itself (`Foo`/`const Foo`),
    // not `Ref<Foo, CPtr>`, so this reuses `Foo`'s own already-registered `nb::class_<Foo>` caster
    // rather than needing separate knowledge of `Ref`.
    template <typename T>
    struct type_caster<{{lib_name}}::diplomat::Optional<T>>
        : optional_caster<{{lib_name}}::diplomat::Optional<T>> {};

    template <typename T, std::size_t E>
    class type_caster<{{lib_name}}::diplomat::span<T, E>> {
        // The type referenced by the span, with const removed.
        using value_type = std::remove_cv_t<T>;
        // Avoid pitfalls with std::vector<bool>
        using vector_value_type = std::conditional_t<std::is_same_v<bool, value_type>, uint8_t, value_type>;
        using ListCaster = list_caster<std::vector<vector_value_type>, value_type>;
        static_assert(sizeof(bool) == sizeof(uint8_t), "bool representation size is unexpected!");


    public:
        using Value = {{lib_name}}::diplomat::span<T, E>;
        Value value = {{lib_name}}::diplomat::span<T, E>();

        static constexpr auto Name = ListCaster::Name;

        template <typename T_>
        using Cast = Value;
        operator Value() { return value; }

        template <typename T_> static constexpr bool can_cast() { return true; }

        // Cast Python -> C++ (nb::cast call)
        bool from_python(handle src, uint8_t flags, cleanup_list* cleanup) noexcept {
            uint8_t local_flags = flags_for_local_caster<T>(flags);

            // First try to convert from ndarray for efficiency
            // Try to get a 1D contiguous array directly using type tags
            if constexpr (is_ndarray_scalar_v<T>) {
                auto caster = make_caster<nb::ndarray<T, ndim<1>>>();
                if (caster.from_python(src, local_flags, cleanup)) {
                    // Create a span from the array data
                    value = {{lib_name}}::diplomat::span<T, E>(caster.value.data(), caster.value.shape(0));
                    return true;
                }
            }

            if constexpr ({{lib_name}}::diplomat::is_pointer_like_v<value_type> && !std::is_copy_constructible_v<value_type>) {
                // `value_type` is an owned opaque wrapper here (e.g. a generated class, not a
                // `Ref`): it can't be copied, and moving it out of the Python objects in the
                // sequence would leave them empty and later double-free their Rust-owned
                // pointee. A span only ever borrows, so instead of building a temporary
                // std::vector<value_type>, just collect each element's existing pointer.
                using RawPtr = decltype(std::declval<value_type&>().AsFFI());

                size_t size;
                PyObject* temp;
                PyObject** o = seq_get(src.ptr(), &size, &temp);
                bool success = o != nullptr;

                auto* ptrs = new std::vector<RawPtr>();
                if (success) {
                    ptrs->reserve(size);
                    for (size_t i = 0; i < size && success; ++i) {
                        make_caster<value_type> item_caster;
                        success = item_caster.from_python(o[i], local_flags, cleanup) &&
                                  item_caster.template can_cast<value_type>();
                        if (success) {
                            ptrs->push_back(item_caster.operator value_type&().AsFFI());
                        }
                    }
                }
                Py_XDECREF(temp);

                if (success) {
                    value = {{lib_name}}::diplomat::span<T, E>(reinterpret_cast<T*>(ptrs->data()), ptrs->size());
                    nb::capsule deleter(ptrs, [](void* data) noexcept {
                        delete (std::vector<RawPtr>*)data;
                        });
                    cleanup->append(deleter.release().ptr());
                    return true;
                }

                delete ptrs;
                return false;
            } else {
                // C++ std::vector<bool> is not allowed, so we convert it to std::vector<uint8_t> for the compiler's sake.
                using U = std::conditional_t<!std::is_same_v<std::remove_cv_t<T>, bool>, std::vector<std::remove_cv_t<T>>, std::vector<uint8_t>>;

                // Are we a bound vector type? If so, we can pass over data directly.
                if (nb::inst_check(src) && nb::isinstance<U>(src)) {
                    U* bound_vec = nb::inst_ptr<U>(src);
                    value = {{lib_name}}::diplomat::span<T, E>(reinterpret_cast<T*>(bound_vec->data()), bound_vec->size());
                    return true;
                }

                // Attempt to convert a native sequence. We must convert all elements & store
                // them in a temporary object which will be cleaned up
                ListCaster caster;
                if (caster.from_python(src, local_flags, cleanup)) {
                    value = {{lib_name}}::diplomat::span<T, E>(reinterpret_cast<T*>(caster.value.data()), caster.value.size());
                    // Move the owning std::vector into a capsule that will live for the duration of the function call.
                    // The address of the vector will change, the address of the region it references won't.
                    nb::capsule deleter(new std::vector<vector_value_type>(std::move(caster.value)), [](void* data) noexcept {
                        delete (std::vector<vector_value_type>*)data;
                        });
                    cleanup->append(deleter.release().ptr());

                    return true;
                }

                return false; // Python type cannot be loaded into a span.
            }
        }

        // Cast C++ -> Python (when returning a span from a C++ function)
        static handle from_cpp({{lib_name}}::diplomat::span<T, E> src, rv_policy policy, cleanup_list* cleanup) {
            using Array = nb::ndarray<std::remove_cv_t<T>, nb::numpy, nb::ndim<1>, nb::f_contig>;
            if constexpr(is_ndarray_scalar_v<T>) {
                nb::object owner;
                if (cleanup->self()) {
                    owner = nb::borrow(cleanup->self());
                    policy = rv_policy::reference;
                }

                 object o = steal(type_caster<Array>::from_cpp(
                    Array((void* )src.data(), {src.size()}, owner),
                    policy, cleanup));

                return o.release();
            } else {
                return ListCaster::from_cpp(src, policy, cleanup);
            }
        }
    };

    template <>
    struct type_caster<{{lib_name}}::diplomat::string_view_for_slice> {
        NB_TYPE_CASTER({{lib_name}}::diplomat::string_view_for_slice, const_name("str"))

        bool from_python(handle src, uint8_t, cleanup_list *) noexcept {
            Py_ssize_t size;
            const char *str = PyUnicode_AsUTF8AndSize(src.ptr(), &size);
            if (!str) {
                PyErr_Clear();
                return false;
            }
            value = {{lib_name}}::diplomat::string_view_for_slice(str, (size_t) size);
            return true;
        }

        static handle from_cpp({{lib_name}}::diplomat::string_view_for_slice value, rv_policy, cleanup_list *) noexcept {
            return PyUnicode_FromStringAndSize(value.data(), value.size());
        }
    };
}

// Return the inner type from next()
// Next returns either a std::unique_ptr or std::optional.
// When T is optional, return inner<T>&&. When T is unique_ptr, just return it.
template<typename T>
struct next_inner_extractor {
    static T&& get(T&& v) { return std::move(v); }
};

template<typename T>
struct next_inner_extractor<std::optional<T>> {
    static T&& get(std::optional<T>&& v) { return std::move(v).value(); }
};

// These are defined in the root module.cpp file.
extern void (*nb_tp_dealloc)(void *);
void diplomat_tp_dealloc(PyObject *self);

// Templating for handling Opaque ZSTs.
// Nanobind cannot handle owned opaques of Rust ZSTs, since by Rust's own standard, pointers to
// ZSTs are always the same address, but Nanobind always assumes that any owned opaque it sees
// contains an address that is *never* repeated.
// So Nanobind handles the first conversion from an owned opaque -> Python just fine,
// but if a function returns an owned opaque at the same ZST address as one it has seen before, then Nanobind panics.
//
// The solution then (without modifying the rest of Diplomat to provide information on what is/isn't an opaque ZST)
// is to hijack functions which return an owned opaque and check if they have ZSTs. This chain starts with
// maybe_op_unwrap and ends with maybe_alloc_zst.
template <class T>
struct is_owned_opaque : std::bool_constant<{{lib_name}}::diplomat::is_pointer_like_v<T> && !std::is_copy_constructible_v<T>> {};

template<typename Return>
inline std::enable_if_t<is_owned_opaque<Return>::value, Return>
maybe_alloc_zst(Return value) {
    // Are we at address 1? Then we're a ZST.
    // Per the Rust allocator (https://github.com/rust-lang/rust/blob/18d13b5332916ffca8eadb9106d54b5b434e9978/library/alloc/src/alloc.rs#L187)
    auto* ptr = value.AsFFI();
    if ((void*)ptr == (void*)0x1) {
        // We don't need to free or drop the pointer, the pointer we allocate below serves the same purpose.
        value.release();
        // We are a ZST, so C++ expects a 0-sized malloc (guaranteed to be a unique pointer):
        return Return::FromFFI((decltype(ptr))malloc(0));
    } else {
        return value;
    }
}

// Given a Return type, map that inner type with maybe_alloc_zst (by unwrapping and re-wrapping the Return type).
// Default implementation for plain owned-opaque types.
template<typename Return>
inline typename std::enable_if_t<is_owned_opaque<Return>::value, Return>
map_inner(Return to_wrap) {
    return maybe_alloc_zst(std::move(to_wrap));
}

template <class Ty>
struct get_diplomat_result : std::false_type {};

template <class T, class E>
struct get_diplomat_result<{{lib_name}}::diplomat::result<T, E>> : std::true_type {
    typedef {{lib_name}}::diplomat::Ok<T> ok;
    typedef {{lib_name}}::diplomat::Err<E> err;

    typedef T success;
    typedef E error;
};

template<typename Return, typename... Args>
inline typename std::enable_if_t<get_diplomat_result<Return>::value, Return>
map_inner(Return to_wrap) {
    using Result = get_diplomat_result<Return>;
    // Either the success type, the error type, or both are owned opaques.
    if (to_wrap.is_ok()) {
        if constexpr(is_owned_opaque<typename Result::success>::value) {
            return typename Result::ok(maybe_alloc_zst(std::move(to_wrap).ok().value()));
        } else {
            return to_wrap;
        }
    } else {
        if constexpr(is_owned_opaque<typename Result::error>::value) {
            return typename Result::err(maybe_alloc_zst(std::move(to_wrap).err().value()));
        } else {
            return to_wrap;
        }
    }
}

// Helper for taking a function of a signature and returning a new function which
// potentially modifies the returned type (if it's a ZST opaque).
template<typename Func>
struct maybe_op_unwrapper {};

// Static function:
template<typename Return, typename... Args>
struct maybe_op_unwrapper<Return(*)(Args...)> {
    typedef std::function<Return(Args...)> result;

    // Get the output of the old function. Call map_inner to unwrap and then re-wrap the inner unique_ptrs.
    static Return bound_map(Return (*f)(Args...), Args... args) {
        auto out = f(args...);
        return map_inner<Return>(std::move(out));
    }

    // Return a std::function for nanobind to parse. This new function will be bound with the old function to call.
    static std::function<Return(Args...)> get_bound_mapper(Return (*f)(Args...)) {
        std::function<Return(Args...)> out = std::bind_front(bound_map, f);
        return out;
    }
};

// Class member function:
template<typename Return, class Class, typename... Args>
struct maybe_op_unwrapper<Return(Class::*)(Args...)> {
    typedef std::function<Return(Class*, Args...)> result;

    static Return bound_map(Return (Class::*f)(Args...), Class* c, Args... args) {
        auto out = (c->*f)(args...);
        return map_inner<Return>(std::move(out));
    }

    static std::function<Return(Class*, Args...)> get_bound_mapper(Return (Class::*f)(Args...)) {
        std::function<Return(Class*, Args...)> out = std::bind_front(maybe_op_unwrapper<Return(Class::*)(Args...)>::bound_map, f);
        return out;
    }
};

// Const member function:
template<typename Return, class Class, typename... Args>
struct maybe_op_unwrapper<Return(Class::*)(Args...) const> {
    typedef std::function<Return(Class*, Args...)> result;

    static Return bound_map(Return (Class::*f)(Args...) const, const Class* c, Args... args) {
        auto out = (c->*f)(args...);
        return map_inner<Return>(std::move(out));
    }

    static std::function<Return(Class*, Args...)> get_bound_mapper(Return (Class::*f)(Args...) const) {
        std::function<Return(Class*, Args...)> out = std::bind_front(maybe_op_unwrapper<Return(Class::*)(Args...) const>::bound_map, f);
        return out;
    }
};

// Given a function that is guaranteed to at some point return a std::unique_ptr (either bare, through optional, or through result).
// Returns a new function that unwraps and then re-wraps that opaque, applying a filter to reallocate any non-unique opaque ZST pointers.
// See maybe_alloc_zst for explanation as to why we call this function.
// Check to see if we're unwrapping a lambda first:
template<typename Func>
typename std::enable_if_t<nanobind::detail::is_lambda_v<std::remove_reference_t<Func>>, typename maybe_op_unwrapper<decltype(&Func::operator())>::result> maybe_op_unwrap(Func&& f) {
    return maybe_op_unwrapper<decltype(&Func::operator())>::get_bound_mapper((nanobind::detail::forward_t<decltype(&Func::operator())>)f);
}

// Then the general case:
template<typename Func>
maybe_op_unwrapper<Func>::result maybe_op_unwrap(Func&& f) {
    return maybe_op_unwrapper<Func>::get_bound_mapper((nanobind::detail::forward_t<Func>)f);
}

template<typename T>
struct lvalue_to_ptr {
    typedef T Type;
    static Type get_value(Type v) {
        return v;
    }
};

template<typename T>
struct lvalue_to_ptr<T&> {
    typedef T* Type;
    static Type get_value(T& v) {
        return &v;
    }
};

// Wrap std::forward, so we forward the type without copying it.
template<typename T>
struct get_cb_with_lvalue_arg {
    typedef T Type;

    static Type&& get_arg(std::remove_reference_t<Type>&& a) {
        return std::forward<Type>(a);
    }

    static Type&& get_arg(std::remove_reference_t<Type>& a) {
        return std::forward<Type>(a);
    }
};

template<typename Return, typename... Args>
struct get_cb_with_lvalue_arg<std::function<Return(Args...)>> {
    typedef std::function<Return(typename lvalue_to_ptr<Args>::Type ...)> Type;

    // Nanobind provides us with a callback that accepts Opaque pointers.
    // C++ will call the returned function with Opaque l-values.
    static std::function<Return(Args...)> get_arg(Type f) {
        return [f](Args... args) -> Return {
            // Given the Opaque l-values, convert them to pointers that Nanobind will accept.
            return f(lvalue_to_ptr<Args>::get_value(args)...);
        };
    }
};

template<typename Func>
struct swap_lvalue_wrapper {};

template<typename Return, typename... Args>
struct swap_lvalue_wrapper<Return(*)(Args...)> {
    // Our original C++ function:
    typedef Return(*original)(Args...);
    // Our Nanobind function with the converted types:
    typedef std::function<Return(typename get_cb_with_lvalue_arg<Args>::Type ...)> result;

    // Return the new function that accepts the types Nanobind wants.
    static result get_converted_func(original f) {
        return [f](get_cb_with_lvalue_arg<Args>::Type... args) -> Return {
            // Call the original C++ function,
            // with the types converted from what Nanobind expects to what C++ expects:
            return (f)(get_cb_with_lvalue_arg<Args>::get_arg(args)...);
        };
    }
};

template<typename Class, typename Return, typename... Args>
struct swap_lvalue_wrapper<Return(Class::*)(Args...)> {
    // Our original C++ function:
    typedef Return(Class::*original)(Args...);
    // Our Nanobind function with the converted types:
    typedef std::function<Return(Class*, typename get_cb_with_lvalue_arg<Args>::Type ...)> result;

    // Return the new function that accepts the types Nanobind wants.
    static result get_converted_func(original f) {
        return [f](Class* c, get_cb_with_lvalue_arg<Args>::Type... args) -> Return {
            // Call the original C++ function,
            // with the types converted from what Nanobind expects to what C++ expects:
            return (c->*f)(get_cb_with_lvalue_arg<Args>::get_arg(args)...);
        };
    }
};

template<typename Class, typename Return, typename... Args>
struct swap_lvalue_wrapper<Return(Class::*)(Args...) const> {
    // Our original C++ function:
    typedef Return(Class::*original)(Args...) const;
    // Our Nanobind function with the converted types:
    typedef std::function<Return(const Class*, typename get_cb_with_lvalue_arg<Args>::Type ...)> result;

    // Return the new function that accepts the types Nanobind wants.
    static result get_converted_func(original f) {
        return [f](const Class* c, get_cb_with_lvalue_arg<Args>::Type... args) -> Return {
            // Call the original C++ function,
            // with the types converted from what Nanobind expects to what C++ expects:
            return (c->*f)(get_cb_with_lvalue_arg<Args>::get_arg(args)...);
        };
    }
};

// Account for maybe_op_unwrap wrapped methods:
template<typename Return, typename... Args>
struct swap_lvalue_wrapper<std::function<Return(Args...)>> {
    // Our original C++ function:
    typedef std::function<Return(Args...)> original;
    // Our Nanobind function with the converted types:
    typedef std::function<Return(typename get_cb_with_lvalue_arg<Args>::Type ...)> result;

    // Return the new function that accepts the types Nanobind wants.
    static result get_converted_func(original f) {
        return [f](get_cb_with_lvalue_arg<Args>::Type... args) -> Return {
            // Call the original C++ function,
            // with the types converted from what Nanobind expects to what C++ expects:
            return (f)(get_cb_with_lvalue_arg<Args>::get_arg(args)...);
        };
    }
};


// Given a function reference, this creates a bound call to take callbacks which take l-value references as args,
// and convert them to pointer args instead (so Nanobind can convert them).
// See https://github.com/rust-diplomat/diplomat/issues/1197 for more
template<typename Func>
swap_lvalue_wrapper<Func>::result swap_lvalue_wrap(Func&& f) {
    return swap_lvalue_wrapper<Func>::get_converted_func((nanobind::detail::forward_t<Func>)f);
}

// Structs with a field that's an opaque Ref (directly, or nested in e.g. a tuple) aren't
// default-constructible, since Ref's own default constructor is private. Binding nb::init<>()
// unconditionally would then fail to compile, so gate it behind a template so the disabled
// branch is never instantiated.
template <typename T, typename... Ts>
inline void maybe_bind_default_init(nb::class_<T, Ts...>& cls) {
    if constexpr (std::is_default_constructible_v<T>) {
        cls.def(nb::init<>());
    }
}
